# Environment Variables — Güvenli Konfigürasyon
# ⚠️  Bu dosya .gitignore'da! Asla gerçek değerleri commit etme.

# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (RDS MySQL) ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_db
DB_USER=app_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Session ──────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_256_BIT_RANDOM_STRING

# ─── AWS (Production) ─────────────────────────────────
AWS_REGION=us-east-1
